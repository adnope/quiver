# Ports
QUIVER_HOST_PORT=8236
QUIVER_INTERNAL_PORT=8080
QUIVER_HTTP_ADDR=0.0.0.0:8080
NETFLOW_PORT=2055
KAFKA_HOST_PORT=9094
QUIVER_CONFIG=/configs/quiver.dev.yaml

# Kafka Brokers
KAFKA_BROKER_INTERNAL=kafka:9092
KAFKA_BROKER_EXTERNAL=localhost:9094

# Kafka Topics
KAFKA_TOPIC_RAW=flow.raw
KAFKA_TOPIC_DLQ=flow.dead_letter

# Database Configuration
POSTGRES_DB=quiver
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=timescaledb
POSTGRES_HOST_EXTERNAL=localhost
POSTGRES_HOST_PORT=5432
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_SSLMODE=disable

QUIVER_DATABASE_DSN=postgres://postgres:postgres@timescaledb:5432/quiver?sslmode=disable
QUIVER_DATABASE_DSN_HOST=postgres://postgres:postgres@localhost:5432/quiver?sslmode=disable

# Security Keys
QUIVER_API_CURSOR_SECRET=verysecretkey_mustbe32byteslong!!!
QUIVER_DEMO_ADMIN_API_KEY=demoadminkey123
REST_INGEST_DEMO_CLIENT_KEY=democlientkey456
NETFLOW_GATEWAY_DEMO_KEY=netflowgatewaykey456
ZEEK_SHIPPER_DEMO_KEY=zeekshipperkey456
